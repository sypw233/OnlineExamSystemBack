# Online Exam System - Environment Variables
# Copy this file to .env and fill in the values

# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/exam_system
DB_USERNAME=postgres
DB_PASSWORD=your_database_password_here

# JWT Configuration (MUST be at least 32 characters)
JWT_SECRET=your_jwt_secret_key_at_least_32_chars

# Baidu Cloud BOS File Storage
BOS_ACCESS_KEY_ID=your_bos_access_key
BOS_SECRET_ACCESS_KEY=your_bos_secret_key
BOS_ENDPOINT=gz.bcebos.com
BOS_BUCKET_NAME=your_bucket_name

# OpenAI API (for AI grading feature)
OPENAI_API_KEY=your_openai_api_key
OPENAI_API_BASE_URL=https://api.openai.com/v1
